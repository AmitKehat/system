import json
import time
import uuid
import redis
import os
from fastapi import APIRouter
from pydantic import BaseModel

router = APIRouter()

from pydantic import BaseModel
from typing import Optional, List, Dict, Any

from typing import Literal, Optional, List, Dict, Any
from pydantic import BaseModel, Field

# ---- Indicator schema models (returned to UI) ----

ParamType = Literal["int", "float", "bool", "select", "string"]

class IndicatorParam(BaseModel):
    key: str
    label: str
    type: ParamType
    default: Any
    min: Optional[float] = None
    max: Optional[float] = None
    step: Optional[float] = None
    options: Optional[List[Any]] = None  # for "select"

class IndicatorDef(BaseModel):
    id: str                 # stable ID used by UI and request payload
    name: str               # display name
    overlay: bool = True    # on price chart vs separate pane (future)
    enabled_by_default: bool = False
    params: List[IndicatorParam] = Field(default_factory=list)

class IndicatorsResponse(BaseModel):
    api_version: str = "1"
    indicators: List[IndicatorDef]

class HistBarsReq(BaseModel):
    symbol: str
    bar_size: str = "1 min"
    duration: str = "1 D"
    end: str = ""
    useRTH: int = 1
    max_rows: int = 5000
    indicators: Optional[list[dict]] = None

@router.post("/hist_bars")
def ib_hist_bars(req: HistBarsReq):
    r = rconn()
    cmd_id = str(uuid.uuid4())
    job_id = str(uuid.uuid4())

    cmd = {
        "cmd_id": cmd_id,
        "job_id": job_id,
        "type": "HIST_BARS",
        "payload": req.model_dump(),
    }

    r.xadd("ib:cmd", {"json": json.dumps(cmd)})

    reply_json = wait_for_reply(r, f"ib:reply:{cmd_id}", timeout_s=30.0)
    if not reply_json:
        return {"ok": False, "error": "timeout_waiting_for_ib_runner"}

    result = json.loads(reply_json)
        
    indicators = req.indicators or []

    if result.get("status") == "OK" and isinstance(result.get("payload"), dict) and indicators:
        result["payload"] = apply_indicators(result["payload"], indicators)

    return result

@router.get("/hist_bars")
def ib_hist_bars_get():
    return {
        "ok": False,
        "error": "Use POST /ib/hist_bars with JSON body. Example: "
                 "{\"symbol\":\"AAPL\",\"bar_size\":\"5 mins\",\"duration\":\"1 D\",\"useRTH\":1}"
    }

def rconn() -> redis.Redis:
    url = os.getenv("REDIS_URL", "redis://redis:6379/0")
    return redis.Redis.from_url(url, decode_responses=True)

def wait_for_reply(r: redis.Redis, stream: str, timeout_s: float = 5.0):
    last_id = "0-0"
    start = time.time()
    while time.time() - start < timeout_s:
        resp = r.xread({stream: last_id}, block=2000, count=1)
        if resp:
            _, entries = resp[0]
            _msg_id, fields = entries[0]
            return fields.get("json")
    return None

def sma_series(bars: list[dict], period: int) -> list[dict]:
    """
    bars: [{time, open, high, low, close, volume}, ...]
    returns: [{time, value}, ...] (Lightweight Charts line series format)
    """
    out: list[dict] = []
    if period <= 0:
        return out

    window_sum = 0.0
    closes: list[float] = []

    for i, b in enumerate(bars):
        c = float(b["close"])
        closes.append(c)
        window_sum += c

        if i >= period:
            window_sum -= closes[i - period]

        if i >= period - 1:
            out.append({"time": int(b["time"]), "value": window_sum / period})

    return out


def apply_indicators(payload: dict, indicators: list[dict]) -> dict:
    """
    payload: your existing hist_bars payload with 'bars'
    indicators: e.g. [{"type":"sma","period":20},{"type":"sma","period":50}]
    """
    bars = payload.get("bars") or []
    ind_out: list[dict] = []

    for ind in indicators or []:
        t = (ind.get("type") or "").lower()
        if t == "sma":
            period = int(ind.get("period", 0))
            ind_out.append({
                "type": "sma",
                "period": period,
                "series": sma_series(bars, period),
            })

    payload["indicators"] = ind_out
    return payload

@router.get("/indicators", response_model=IndicatorsResponse)
def ib_indicators():
    """
    Frontend reads this to build dropdown + settings UI.
    Single source of truth for which indicators/params are supported.
    """
    return IndicatorsResponse(
        indicators=[
            IndicatorDef(
                id="sma",
                name="SMA",
                overlay=True,
                enabled_by_default=False,
                params=[
                    IndicatorParam(key="period", label="Period", type="int", default=20, min=1, max=500, step=1),
                    IndicatorParam(key="source", label="Source", type="select", default="close",
                                   options=["close", "open", "high", "low"]),
                ],
            ),
            IndicatorDef(
                id="ema",
                name="EMA",
                overlay=True,
                enabled_by_default=False,
                params=[
                    IndicatorParam(key="period", label="Period", type="int", default=20, min=1, max=500, step=1),
                    IndicatorParam(key="source", label="Source", type="select", default="close",
                                   options=["close", "open", "high", "low"]),
                ],
            ),
            IndicatorDef(
                id="vwma",
                name="VWMA",
                overlay=True,
                enabled_by_default=False,
                params=[
                    IndicatorParam(key="period", label="Period", type="int", default=20, min=1, max=500, step=1),
                ],
            ),
        ]
    )

@router.post("/ping")
def ib_ping():
    r = rconn()
    cmd_id = str(uuid.uuid4())
    job_id = str(uuid.uuid4())

    cmd = {
        "cmd_id": cmd_id,
        "job_id": job_id,
        "type": "PING",
        "payload": {},
    }

    # send command to runner
    r.xadd("ib:cmd", {"json": json.dumps(cmd)})

    # wait for runner reply
    reply_json = wait_for_reply(r, f"ib:reply:{cmd_id}", timeout_s=5.0)
    if not reply_json:
        return {"ok": False, "error": "timeout_waiting_for_ib_runner"}

    return json.loads(reply_json)

