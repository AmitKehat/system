from __future__ import annotations

import json
import os
import time
import uuid
from dataclasses import dataclass
from typing import Any, Dict, Optional

import redis
from ib_insync import IB

from datetime import datetime, date, time as dtime, timezone

def ib_bar_time_to_epoch_seconds(bar_date) -> int:
    """
    Convert IB bar date/time into epoch seconds (int).
    Handles datetime, date, and IB string formats.
    """
    # IB sometimes returns strings
    if isinstance(bar_date, str):
        s = bar_date.strip()

        # Daily bars often come as YYYYMMDD
        if len(s) == 8 and s.isdigit():
            d = datetime.strptime(s, "%Y%m%d").date()
            dt = datetime.combine(d, dtime(0, 0), tzinfo=timezone.utc)
            return int(dt.timestamp())

        # Try ISO-like datetime
        try:
            dt = datetime.fromisoformat(s.replace("  ", " ").replace(" ", "T"))
            if dt.tzinfo is None:
                dt = dt.replace(tzinfo=timezone.utc)
            return int(dt.timestamp())
        except Exception:
            return 0

    # date (daily bars)
    if isinstance(bar_date, date) and not isinstance(bar_date, datetime):
        dt = datetime.combine(bar_date, dtime(0, 0), tzinfo=timezone.utc)
        return int(dt.timestamp())

    # datetime (intraday bars)
    if isinstance(bar_date, datetime):
        dt = bar_date
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=timezone.utc)
        return int(dt.timestamp())

    return 0

def to_epoch_seconds(x) -> int:
    """
    IB can return bar times as:
      - datetime.datetime (intraday)
      - datetime.date (daily)
      - string (sometimes)
    Normalize to unix epoch seconds (int).
    """
    if x is None:
        return 0

    if isinstance(x, (int, float)):
        return int(x)

    if isinstance(x, datetime):
        if x.tzinfo is None:
            x = x.replace(tzinfo=timezone.utc)
        return int(x.timestamp())

    if isinstance(x, date):
        # date has no timestamp(); assume midnight UTC
        dt = datetime.combine(x, dtime.min).replace(tzinfo=timezone.utc)
        return int(dt.timestamp())

    if isinstance(x, str):
        s = x.strip()
        # common IB formats: "YYYYMMDD" or "YYYYMMDD  HH:MM:SS" or ISO
        for fmt in ("%Y%m%d  %H:%M:%S", "%Y%m%d %H:%M:%S", "%Y%m%d"):
            try:
                dt = datetime.strptime(s, fmt).replace(tzinfo=timezone.utc)
                return int(dt.timestamp())
            except ValueError:
                pass
        try:
            dt = datetime.fromisoformat(s)
            if dt.tzinfo is None:
                dt = dt.replace(tzinfo=timezone.utc)
            return int(dt.timestamp())
        except Exception:
            return 0

    return 0

CMD_STREAM = os.getenv("IB_CMD_STREAM", "ib:cmd")
REPLY_PREFIX = os.getenv("IB_REPLY_PREFIX", "ib:reply:")
REDIS_URL = os.getenv("REDIS_URL", "redis://redis:6379/0")

IB_HOST = os.getenv("IB_HOST", "ibgateway")
IB_PORT = int(os.getenv("IB_PORT", "4002"))
IB_CLIENT_ID = int(os.getenv("IB_CLIENT_ID", "1"))

JOB_EVENTS_PREFIX = os.getenv("JOB_EVENTS_PREFIX", "job:events:")


@dataclass
class Cmd:
    cmd_id: str
    job_id: Optional[str]
    type: str
    payload: Dict[str, Any]

def ensure_ib_connected(ib):
    if ib is None or not ib.isConnected():
        print("[ib-runner] IB not connected, reconnecting...")
        try:
            ib.disconnect()
        except Exception:
            pass
        ib = connect_ib()
    return ib

def rconn() -> redis.Redis:
    return redis.Redis.from_url(REDIS_URL, decode_responses=True)


def publish_job_event(r: redis.Redis, job_id: str, event: Dict[str, Any]) -> None:
    stream = f"{JOB_EVENTS_PREFIX}{job_id}"
    r.xadd(stream, {"json": json.dumps(event)}, maxlen=5000, approximate=True)


def reply(r: redis.Redis, cmd_id: str, status: str, payload: Any = None, error: Optional[str] = None) -> None:
    stream = f"{REPLY_PREFIX}{cmd_id}"
    msg = {"cmd_id": cmd_id, "status": status, "payload": payload, "error": error}
    r.xadd(stream, {"json": json.dumps(msg)}, maxlen=1000, approximate=True)


def connect_ib() -> IB:
    ib = IB()
    # Retry loop because IB Gateway may take time to be ready
    for i in range(60):
        try:
            ib.connect(IB_HOST, IB_PORT, clientId=IB_CLIENT_ID, timeout=5)
            return ib
        except Exception as e:
            print(f"[ib-runner] IB connect failed ({i+1}/60): {e}")
            time.sleep(2)
    raise RuntimeError("IB Gateway not reachable after retries")


def handle_server_time(ib: IB) -> Dict[str, Any]:
    t = ib.reqCurrentTime()  # datetime
    return {"server_time": t.isoformat()}

def handle_hist_bars(ib: "IB", r: "redis.Redis", cmd: "Cmd") -> None:
    """
    Fetch historical bars from IB and return Lightweight Charts-ready JSON.
    """
    p = cmd.payload
    symbol = p["symbol"]
    bar_size = p.get("bar_size", "1 min")
    duration = p.get("duration", "1 D")
    end = p.get("end", "")  # "" means now
    useRTH = int(p.get("useRTH", 1))
    max_rows = int(p.get("max_rows", 5000))

    from ib_insync import Stock, util

    contract = Stock(symbol, "SMART", "USD")
    bars = ib.reqHistoricalData(
        contract,
        endDateTime=end,
        durationStr=duration,
        barSizeSetting=bar_size,
        whatToShow="TRADES",
        useRTH=useRTH,
        formatDate=1,
    )

    df = util.df(bars)
    if df is None or df.empty or "date" not in df.columns:
        reply(r, cmd.cmd_id, "OK", payload={"symbol": symbol, "bar_size": bar_size, "duration": duration, "useRTH": useRTH, "rows": 0, "bars": []})
        return

    # Build output bars with robust time conversion
    n = min(len(df), max_rows)
    start = max(0, len(df) - n)

    bars_out = []
    for i in range(start, len(df)):
        row = df.iloc[i]
        t = ib_bar_time_to_epoch_seconds(row["date"])
        if not t:
            # Skip bad rows instead of crashing / returning invalid times
            continue

        bars_out.append(
            {
                "time": int(t),
                "open": float(row["open"]),
                "high": float(row["high"]),
                "low": float(row["low"]),
                "close": float(row["close"]),
                "volume": float(row.get("volume", 0) or 0),
            }
        )

    payload = {
        "symbol": symbol,
        "bar_size": bar_size,
        "duration": duration,
        "useRTH": useRTH,
        "rows": len(bars_out),
        "bars": bars_out,
    }
    reply(r, cmd.cmd_id, "OK", payload=payload)

def parse_cmd(raw_json: str) -> Cmd:
    obj = json.loads(raw_json)
    return Cmd(
        cmd_id=obj["cmd_id"],
        job_id=obj.get("job_id"),
        type=obj["type"],
        payload=obj.get("payload") or {},
    )


def main() -> None:
    print(
        f"[ib-runner] starting. redis={REDIS_URL} cmd_stream={CMD_STREAM} "
        f"ib={IB_HOST}:{IB_PORT} clientId={IB_CLIENT_ID}"
    )

    r = rconn()
    ib = connect_ib()
    print("[ib-runner] connected to IB")

    last_id = "0-0"
    while True:
        # block for up to 5 seconds waiting for new commands
        try:
            resp = r.xread({CMD_STREAM: last_id}, block=5000, count=10)
        except redis.exceptions.ResponseError as e:
            # can happen on redis failover / connection reset ("UNBLOCKED ...")
            print(f"[ib-runner] redis xread response error: {e}")
            time.sleep(0.2)
            continue
        except redis.exceptions.RedisError as e:
            print(f"[ib-runner] redis error: {e}")
            time.sleep(0.5)
            continue

        if not resp:
            continue

        for _stream_name, entries in resp:
            for entry_id, fields in entries:
                last_id = entry_id
                raw = fields.get("json")
                if not raw:
                    continue

                try:
                    cmd = parse_cmd(raw)
                    print(f"[ib-runner] got cmd={cmd.type} id={cmd.cmd_id}")

                    if cmd.type == "PING":
                        payload = {
                            "status": "ok",
                            "service": "ib_runner",
                            "ts": time.time(),
                        }
                        reply(r, cmd.cmd_id, "OK", payload=payload)
                        continue

                    if cmd.type == "SERVER_TIME":
                        ib = ensure_ib_connected(ib)
                        payload = handle_server_time(ib)
                        reply(r, cmd.cmd_id, "OK", payload=payload)
                        continue

                    if cmd.type == "HIST_BARS":
                        ib = ensure_ib_connected(ib)
                        handle_hist_bars(ib, r, cmd)
                        continue

                    reply(r, cmd.cmd_id, "ERROR", error=f"Unknown cmd type: {cmd.type}")

                except Exception as e:
                    # never crash the daemon; reply error
                    err = f"{type(e).__name__}: {e}"
                    print(f"[ib-runner] error: {err}")
                    try:
                        reply(r, cmd.cmd_id if "cmd" in locals() else "unknown", "ERROR", error=err)
                    except Exception:
                        pass


if __name__ == "__main__":
    main()
