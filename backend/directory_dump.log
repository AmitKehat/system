            "folder": run.folder,
            "config_json": run.config_json,
            "error": getattr(run, "error", None),
            "progress_current": getattr(run, "progress_current", None),
            "progress_total": getattr(run, "progress_total", None),
            "progress_msg": getattr(run, "progress_msg", None),
