root/docker-compose.yml

services:
  postgres:
    image: postgres:16
    container_name: trading_postgres
    environment:
      POSTGRES_USER: ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
      POSTGRES_DB: ${DB_NAME}
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER} -d ${DB_NAME}"]
      interval: 5s
      timeout: 5s
      retries: 20

  redis:
    image: redis:7
    container_name: trading_redis
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 20

  ibgateway:
    image: ghcr.io/gnzsnz/ib-gateway:stable
    container_name: trading_ibgateway
    volumes:
      - ./ibc/config.ini.tmpl:/home/ibgateway/ibc/config.ini.tmpl:ro
    environment:
      TWS_USERID: ${IB_USERID}
      TWS_PASSWORD: ${IB_PASSWORD}
      TRADING_MODE: ${IB_MODE}
      VNC_SERVER_PASSWORD: ${IB_VNC_PASSWORD}
      TWOFA_TIMEOUT_ACTION: restart
      RELOGIN_AFTER_TWOFA_TIMEOUT: "yes"
    ports:
      - "4004:4004"
      - "5900:5900"
    restart: unless-stopped
      
  api:
    build: .
    container_name: trading_api
    command: uvicorn src.api.main:app --host 0.0.0.0 --port 8000
    environment:
      DATABASE_URL: postgresql+psycopg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
      REDIS_URL: redis://${REDIS_HOST}:${REDIS_PORT}/0
      CELERY_BROKER_URL: redis://${REDIS_HOST}:${REDIS_PORT}/0
      CELERY_RESULT_BACKEND: redis://${REDIS_HOST}:${REDIS_PORT}/1
    ports:
      - "8000:8000"
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    restart: unless-stopped

  worker:
    build: .
    container_name: trading_worker
    command: celery -A src.worker.celery_app.celery_app worker --loglevel=INFO
    environment:
      DATABASE_URL: postgresql+psycopg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
      REDIS_URL: redis://${REDIS_HOST}:${REDIS_PORT}/0
      CELERY_BROKER_URL: redis://${REDIS_HOST}:${REDIS_PORT}/0
      CELERY_RESULT_BACKEND: redis://${REDIS_HOST}:${REDIS_PORT}/1
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    restart: unless-stopped

  ib_runner:
    build: .
    container_name: trading_ib_runner
    command: python -m src.ib.runner_daemon
    environment:
      IB_HOST: ibgateway
      IB_PORT: 4004
      IB_CLIENT_ID: 101
      IB_CMD_STREAM: ib:cmd
      IB_REPLY_PREFIX: "ib:reply:"
      REDIS_URL: redis://${REDIS_HOST}:${REDIS_PORT}/0
    depends_on:
      redis:
        condition: service_healthy
      ibgateway:
        condition: service_started
    restart: unless-stopped

volumes:
  pgdata:
