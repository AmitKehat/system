# Admin
# -----------------------------------------------------------------------------

@app.post("/admin/runs/cleanup_stale")
def admin_cleanup_stale():
    session = get_session()
    try:
        n = cleanup_stale_running(session)
        session.commit()
        return {"cleaned": n}
    finally:
        session.close()
